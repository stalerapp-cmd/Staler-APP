# Server
PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_SECRET_KEY=your_supabase_secret_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# LibEuFin Bank
LIBEUFIN_BANK_URL=http://localhost:8080
BANK_ADMIN_USERNAME=admin
BANK_ADMIN_PASSWORD=your_bank_admin_password
BANK_EXCHANGE_USERNAME=exchange
BANK_EXCHANGE_PASSWORD=your_exchange_password

# Taler
TALER_BANK_URL=your_taler_bank_url
TALER_BANK_ADMIN_USER=admin
TALER_BANK_ADMIN_PASSWORD=your_password
TALER_EXCHANGE_USER=exchange
TALER_EXCHANGE_PASSWORD=your_password
TALER_EXCHANGE_URL=your_exchange_url
TALER_CURRENCY=PS

# Limits
MAX_DEPOSIT=10000
MAX_WITHDRAWAL=10000
ALLOW_OVERDRAFT=false

# Email
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASSWORD=your_gmail_app_password

# Logs
LOG_LEVEL=info
LOG_FILE=/tmp/staler-backend.log

# Encryption
ENCRYPTION_KEY=your_32_char_encryption_key
MESSAGE_ENCRYPTION_KEY=your_message_encryption_key

# React
REACT_APP_API_URL=http://localhost:5000
REACT_APP_MAX_WITHDRAWAL=10000

# SMS (Infobip)
INFOBIP_API_KEY=your_infobip_api_key
INFOBIP_BASE_URL=https://api.infobip.com
INFOBIP_SENDER=InfoSMS

# Twilio (disabled)
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
# TWILIO_PHONE_NUMBER=your_twilio_number